# ─── Database ────────────────────────────────────────────────────────────────
# Connects to PostgreSQL running inside Docker on localhost:5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/monday1_dev"

# ─── NestJS API ──────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Next.js Web ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
